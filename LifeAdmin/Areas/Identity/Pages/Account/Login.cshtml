@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="modern-auth-page">
    <div class="modern-auth-shell">
        <div class="row g-0">
            <div class="col-xl-5 col-lg-6">
                <div class="modern-auth-form-panel">
                    <div class="modern-auth-top">
                        <span class="modern-auth-badge">Welcome back</span>
                        <h1 class="modern-auth-title">Log in to LifeAdmin</h1>
                        <p class="modern-auth-subtitle">
                            Continue managing your tasks, notes, documents and personal workspace in one place.
                        </p>
                    </div>

                    <form id="account" method="post" class="modern-auth-form">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="modern-field">
                            <label asp-for="Input.Email" class="modern-label">Email</label>
                            <input asp-for="Input.Email"
                                   class="form-control modern-input"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="modern-field">
                            <label asp-for="Input.Password" class="modern-label">Password</label>
                            <input asp-for="Input.Password"
                                   class="form-control modern-input"
                                   autocomplete="current-password"
                                   aria-required="true"
                                   placeholder="Enter your password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="modern-auth-row">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label asp-for="Input.RememberMe" class="form-check-label">
                                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                                </label>
                            </div>

                            <a id="forgot-password" asp-page="./ForgotPassword" class="modern-inline-link">
                                Forgot password?
                            </a>
                        </div>

                        <button id="login-submit" type="submit" class="btn modern-primary-btn w-100">
                            Log in
                        </button>

                        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                        {
                            <div class="modern-divider">
                                <span>or continue with</span>
                            </div>

                            <form id="external-account"
                                  asp-page="./ExternalLogin"
                                  asp-route-returnUrl="@Model.ReturnUrl"
                                  method="post"
                                  class="modern-social-grid">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit"
                                            class="btn modern-social-btn"
                                            name="provider"
                                            value="@provider.Name"
                                            title="Log in using your @provider.DisplayName account">
                                        @provider.DisplayName
                                    </button>
                                }
                            </form>
                        }

                        <div class="modern-auth-footer">
                            <span class="text-muted">Don’t have an account?</span>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create one</a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-xl-7 col-lg-6 d-none d-lg-flex">
                <div class="modern-auth-side">
                    <div class="modern-auth-side-content">
                        <span class="modern-side-kicker">Productivity Hub</span>
                        <h2 class="modern-side-title">A cleaner way to organize your day.</h2>
                        <p class="modern-side-text">
                            LifeAdmin gives you one elegant workspace for tasks, notes, documents, categories and admin tools.
                        </p>

                        <div class="modern-feature-grid">
                            <div class="modern-feature-card">
                                <div class="modern-feature-icon">✓</div>
                                <div>
                                    <strong>Task clarity</strong>
                                    <p>Create, track and filter work with a cleaner workflow.</p>
                                </div>
                            </div>

                            <div class="modern-feature-card">
                                <div class="modern-feature-icon">✦</div>
                                <div>
                                    <strong>Smart organization</strong>
                                    <p>Keep notes, documents and categories in one place.</p>
                                </div>
                            </div>

                            <div class="modern-feature-card">
                                <div class="modern-feature-icon">⚙</div>
                                <div>
                                    <strong>Admin ready</strong>
                                    <p>Role management, user details and scalable architecture.</p>
                                </div>
                            </div>
                        </div>

                        <div class="modern-auth-stats">
                            <div class="modern-stat-card">
                                <span class="modern-stat-number">All-in-one</span>
                                <span class="modern-stat-label">Workspace experience</span>
                            </div>
                            <div class="modern-stat-card">
                                <span class="modern-stat-number">Modern</span>
                                <span class="modern-stat-label">Clean dashboard UI</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}