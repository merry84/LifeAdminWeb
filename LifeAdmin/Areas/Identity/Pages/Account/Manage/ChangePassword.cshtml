@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
    Layout = "_Layout";
}

<div class="manage-form-shell">
    <div class="manage-form-header mb-4">
        <h2 class="manage-form-title">@ViewData["Title"]</h2>
        <p class="manage-form-subtitle mb-0">
            Update your password to keep your account secure.
        </p>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <form id="change-password-form" method="post" class="manage-form">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

        <div class="mb-3">
            <label asp-for="Input.OldPassword" class="form-label"></label>
            <input asp-for="Input.OldPassword"
                   class="form-control"
                   autocomplete="current-password"
                   aria-required="true"
                   placeholder="Enter your current password" />
            <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.NewPassword" class="form-label"></label>
            <input asp-for="Input.NewPassword"
                   class="form-control"
                   autocomplete="new-password"
                   aria-required="true"
                   placeholder="Enter your new password" />
            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Input.ConfirmPassword" class="form-label"></label>
            <input asp-for="Input.ConfirmPassword"
                   class="form-control"
                   autocomplete="new-password"
                   aria-required="true"
                   placeholder="Confirm your new password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="w-100 btn btn-primary manage-submit-btn">
            Update password
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}