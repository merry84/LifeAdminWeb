@page
@model RegisterModel

@{
    ViewData["Title"] = "Register";
}

<div class="modern-auth-page">
    <div class="modern-auth-shell">
        <div class="row g-0">
            <div class="col-xl-5 col-lg-6">
                <div class="modern-auth-form-panel">
                    <div class="modern-auth-top">
                        <span class="modern-auth-badge">Create account</span>
                        <h1 class="modern-auth-title">Join LifeAdmin</h1>
                        <p class="modern-auth-subtitle">
                            Create your account and start organizing your daily workflow in one secure workspace.
                        </p>
                    </div>

                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="modern-auth-form">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="modern-field">
                                    <label asp-for="Input.FirstName" class="modern-label"></label>
                                    <input asp-for="Input.FirstName" class="form-control modern-input" placeholder="First name" />
                                    <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="modern-field">
                                    <label asp-for="Input.LastName" class="modern-label"></label>
                                    <input asp-for="Input.LastName" class="form-control modern-input" placeholder="Last name" />
                                    <span asp-validation-for="Input.LastName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="modern-field">
                            <label asp-for="Input.DisplayName" class="modern-label">Display name</label>
                            <input asp-for="Input.DisplayName"
                                   class="form-control modern-input"
                                   autocomplete="nickname"
                                   placeholder="Optional display name" />
                            <small class="modern-help-text">If left empty, your first and last name will be used.</small>
                            <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
                        </div>

                        <div class="modern-field">
                            <label asp-for="Input.Email" class="modern-label">Email</label>
                            <input asp-for="Input.Email"
                                   class="form-control modern-input"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="name@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="modern-field">
                            <label asp-for="Input.Password" class="modern-label">Password</label>
                            <input asp-for="Input.Password"
                                   class="form-control modern-input"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Create password" />
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="modern-field">
                            <label asp-for="Input.ConfirmPassword" class="modern-label">Confirm password</label>
                            <input asp-for="Input.ConfirmPassword"
                                   class="form-control modern-input"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Repeat password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button id="registerSubmit" type="submit" class="btn modern-primary-btn w-100">
                            Create account
                        </button>

                        <div class="modern-auth-footer">
                            <span class="text-muted">Already have an account?</span>
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Log in</a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-xl-7 col-lg-6 d-none d-lg-flex">
                <div class="modern-auth-side">
                    <div class="modern-auth-side-content">
                        <span class="modern-side-kicker">Get started</span>
                        <h2 class="modern-side-title">Build your personal productivity space.</h2>
                        <p class="modern-side-text">
                            Start with a clean account setup and unlock tasks, profile management, admin tools and better organization.
                        </p>

                        <div class="modern-feature-grid">
                            <div class="modern-feature-card">
                                <div class="modern-feature-icon">👤</div>
                                <div>
                                    <strong>Profile ready</strong>
                                    <p>Use display name and profile details in a clean personal page.</p>
                                </div>
                            </div>

                            <div class="modern-feature-card">
                                <div class="modern-feature-icon">📝</div>
                                <div>
                                    <strong>Better productivity</strong>
                                    <p>Manage tasks, notes and documents from one place.</p>
                                </div>
                            </div>

                            <div class="modern-feature-card">
                                <div class="modern-feature-icon">🔐</div>
                                <div>
                                    <strong>Secure access</strong>
                                    <p>Built on ASP.NET Core Identity with role-based protection.</p>
                                </div>
                            </div>
                        </div>

                        <div class="modern-auth-stats">
                            <div class="modern-stat-card">
                                <span class="modern-stat-number">Fast</span>
                                <span class="modern-stat-label">Simple onboarding</span>
                            </div>
                            <div class="modern-stat-card">
                                <span class="modern-stat-number">Clean</span>
                                <span class="modern-stat-label">Modern user flow</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}