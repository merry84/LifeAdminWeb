@model IEnumerable<ViewModels.DocumentListViewModel>

@{
    ViewData["Title"] = "Documents";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Documents</h1>
        <a asp-action="Upload" class="btn btn-primary">Upload Document</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No documents uploaded yet.</div>
    }
    else
    {
        <table class="table table-striped table-bordered bg-white">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>File</th>
                    <th>Uploaded On</th>
                    <th>Size</th>
                    <th>Owner</th>
                    <th style="width: 220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model)
                {
                    <tr>
                        <td>@doc.Title</td>
                        <td>@doc.FileName</td>
                        <td>@doc.UploadedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@(doc.FileSize / 1024) KB</td>
                        <td>@doc.OwnerUserName</td>
                        <td>
                            <a asp-action="Download" asp-route-id="@doc.Id" class="btn btn-success btn-sm me-2">Download</a>
                            <a asp-action="Delete" asp-route-id="@doc.Id" class="btn btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>