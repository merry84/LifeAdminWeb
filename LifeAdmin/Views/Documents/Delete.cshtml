@model ViewModels.DocumentDeleteViewModel

@{
    ViewData["Title"] = "Delete Document";
}

<div class="container mt-4">
    <h1 class="mb-3">Delete Document</h1>

    <div class="alert alert-warning">
        Are you sure you want to delete this document?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Title</dt>
        <dd class="col-sm-9">@Model.Title</dd>

        <dt class="col-sm-3">File Name</dt>
        <dd class="col-sm-9">@Model.FileName</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="All" class="btn btn-secondary">Cancel</a>
    </form>
</div>