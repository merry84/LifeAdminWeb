@{
    ViewData["Title"] = "About LifeAdmin";
}

<section class="dark-page-section py-4 py-lg-5">
    <div class="container">
        <div class="dark-page-shell">
            <div class="dark-page-hero mb-4">
                <span class="dark-page-badge">About LifeAdmin</span>
                <h1 class="dark-page-title mt-3">A modern productivity project built with ASP.NET Core MVC</h1>
                <p class="dark-page-subtitle mb-0">
                    LifeAdmin is a SoftUni project focused on creating a complete and practical web application
                    for managing tasks, notes, categories, documents, and user profiles in one secure environment.
                </p>
            </div>

            <div class="row g-4">
                <div class="col-lg-7">
                    <div class="dark-page-card h-100">
                        <h2 class="dark-section-title">Project overview</h2>
                        <p>
                            The goal of LifeAdmin is to provide a clean and structured workspace for personal productivity.
                            The project combines real application architecture with practical features and a modern UI.
                        </p>
                        <p class="mb-0">
                            It includes both user and administrator functionality, with attention to clean code,
                            layered structure, validation, testing, role-based access, and responsive design.
                        </p>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="dark-page-card h-100">
                        <h2 class="dark-section-title">Project highlights</h2>
                        <ul class="dark-list mb-0">
                            <li>ASP.NET Core MVC with layered architecture</li>
                            <li>Entity Framework Core with SQL Server LocalDB</li>
                            <li>ASP.NET Core Identity authentication and authorization</li>
                            <li>CRUD operations, search, filtering, pagination, and soft delete</li>
                            <li>Service layer covered by unit tests</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-1">
                <div class="col-lg-6">
                    <div class="dark-page-card h-100">
                        <h2 class="dark-section-title">Main features</h2>

                        <div class="dark-mini-card">
                            <h6>Task Management</h6>
                            <p>CRUD operations, filtering, pagination, and soft delete support.</p>
                        </div>

                        <div class="dark-mini-card">
                            <h6>Notes and Categories</h6>
                            <p>Structured content organization with search and better usability.</p>
                        </div>

                        <div class="dark-mini-card">
                            <h6>Documents and Profile</h6>
                            <p>Upload, delete, restore, and manage personal profile information.</p>
                        </div>

                        <div class="dark-mini-card mb-0">
                            <h6>Dashboard and Admin Area</h6>
                            <p>Statistics, user management, and role-based administrative tools.</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="dark-page-card h-100">
                        <h2 class="dark-section-title">Technologies used</h2>
                        <div class="dark-tags mb-4">
                            <span>ASP.NET Core MVC</span>
                            <span>C#</span>
                            <span>EF Core</span>
                            <span>SQL Server</span>
                            <span>Identity</span>
                            <span>Bootstrap 5</span>
                            <span>NUnit</span>
                            <span>EF Core InMemory</span>
                        </div>

                        <h2 class="dark-section-title">What I learned</h2>
                        <ul class="dark-list mb-0">
                            <li>Building a complete MVC web application with clean structure</li>
                            <li>Separating business logic into services and view models</li>
                            <li>Working with authentication, roles, and authorization</li>
                            <li>Improving quality through testing and code coverage</li>
                            <li>Creating a more polished and consistent user interface</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="dark-page-card mt-4">
                <h2 class="dark-section-title">About the developer</h2>
                <p>
                    My name is Mariya Tsvetkova and I am currently studying Software Engineering at SoftUni.
                    I am focused on improving my skills in C#, ASP.NET Core, databases, clean architecture,
                    testing, and modern web application development.
                </p>
                <p class="mb-0">
                    LifeAdmin is an important step in my learning journey because it combines backend logic,
                    data access, authentication, testing, and UI design in one complete project.
                </p>
            </div>
        </div>
    </div>
</section>