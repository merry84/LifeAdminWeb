@{
    ViewData["Title"] = "About LifeAdmin";
}

<section class="about-page py-4 py-lg-5">
    <div class="container">
        <div class="about-shell">
            <div class="about-header mb-4">
                <span class="about-badge">About LifeAdmin</span>
                <h1 class="about-title mt-3">A clean and practical productivity application</h1>
                <p class="about-subtitle mb-0">
                    LifeAdmin is an ASP.NET Core MVC project created as part of my SoftUni training.
                    It brings together task management, notes, categories, documents, profile features,
                    and administration in one structured web application.
                </p>
            </div>

            <div class="row g-4">
                <div class="col-lg-7">
                    <div class="about-card h-100">
                        <h2 class="about-section-title">Project overview</h2>
                        <p>
                            The goal of LifeAdmin is to provide a simple and well-organized environment for
                            personal productivity. The project is designed around clean structure, practical
                            functionality, and a user-friendly interface.
                        </p>
                        <p class="mb-0">
                            It includes both user and administrator features, with attention to validation,
                            role-based access, maintainable architecture, and responsive design.
                        </p>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="about-card h-100">
                        <h2 class="about-section-title">Project highlights</h2>
                        <ul class="about-list mb-0">
                            <li>Layered architecture with clear separation of concerns</li>
                            <li>ASP.NET Core MVC with Entity Framework Core</li>
                            <li>SQL Server LocalDB and ASP.NET Core Identity</li>
                            <li>Responsive UI with a modern glass-style feel</li>
                            <li>Service layer covered by unit tests</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-1">
                <div class="col-lg-6">
                    <div class="about-card h-100">
                        <h2 class="about-section-title">Main features</h2>

                        <div class="about-feature">
                            <h6>Task Management</h6>
                            <p>CRUD operations, filtering, pagination, and soft delete functionality.</p>
                        </div>

                        <div class="about-feature">
                            <h6>Notes and Categories</h6>
                            <p>Organized note management with search and better content structure.</p>
                        </div>

                        <div class="about-feature">
                            <h6>Documents and Profile</h6>
                            <p>Document upload and recovery, along with editable user profile information.</p>
                        </div>

                        <div class="about-feature mb-0">
                            <h6>Admin Area and Dashboard</h6>
                            <p>Administrative tools, role-based access, and useful statistics overview.</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="about-card h-100">
                        <h2 class="about-section-title">Technologies used</h2>

                        <div class="about-tags mb-4">
                            <span>ASP.NET Core MVC</span>
                            <span>C#</span>
                            <span>Entity Framework Core</span>
                            <span>SQL Server</span>
                            <span>ASP.NET Core Identity</span>
                            <span>Bootstrap 5</span>
                            <span>NUnit</span>
                            <span>EF Core InMemory</span>
                            <span>GitHub</span>
                        </div>

                        <h2 class="about-section-title">What I learned</h2>
                        <ul class="about-list mb-0">
                            <li>Building a complete MVC application with layered architecture</li>
                            <li>Structuring services, view models, and data access in a maintainable way</li>
                            <li>Working with authentication, authorization, and role management</li>
                            <li>Creating responsive UI with consistent styling across pages</li>
                            <li>Writing unit tests and improving code quality through coverage</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="about-card mt-4">
                <h2 class="about-section-title">About the developer</h2>
                <p>
                    My name is Mariya Tsvetkova and I am a Software Engineering student at SoftUni.
                    I am focused on improving my skills in C#, ASP.NET Core, databases, clean architecture,
                    and modern web development.
                </p>
                <p class="mb-0">
                    LifeAdmin is an important project in my learning journey because it combines backend logic,
                    database design, testing, user management, and UI development in one complete application.
                </p>
            </div>
        </div>
    </div>
</section>