@using ViewModels.DashboardViewModels
@model DashboardStatsViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4 admin-dark">
    <h1 class="admin-title mb-2">Dashboard</h1>
    <p class="admin-subtitle mb-4">
        Overview of your tasks, notes and categories.
    </p>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="admin-stat-card">
                <span>My Tasks</span>
                <strong>@Model.TotalTasks</strong>
            </div>
        </div>

        <div class="col-md-4">
            <div class="admin-stat-card">
                <span>My Notes</span>
                <strong>@Model.TotalNotes</strong>
            </div>
        </div>

        <div class="col-md-4">
            <div class="admin-stat-card">
                <span>Categories</span>
                <strong>@Model.CategoriesCount</strong>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="admin-card">
                <h4>Quick Overview</h4>
                <ul class="admin-list mb-0">
                    <li>Tasks: @Model.TotalTasks</li>
                    <li>Notes: @Model.TotalNotes</li>
                    <li>Categories: @Model.CategoriesCount</li>
                </ul>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="admin-card">
                <h4>Quick Actions</h4>

                <a asp-area=""
                   asp-controller="Tasks"
                   asp-action="All"
                   class="admin-btn">
                    Go to My Tasks
                </a>

                <a asp-area=""
                   asp-controller="Notes"
                   asp-action="All"
                   class="admin-btn">
                    Open Notes
                </a>

                <a asp-area=""
                   asp-controller="Documents"
                   asp-action="All"
                   class="admin-btn-outline">
                    View Documents
                </a>
            </div>
        </div>
    </div>
</div>