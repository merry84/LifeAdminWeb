@{
    ViewData["Title"] = "Home";
}

<section class="home-dark py-4 py-lg-5">
    <div class="container">
        <div class="dark-hero">
            <div class="row g-4 align-items-center">
                <div class="col-lg-6">
                    <div class="dark-hero-content">
                        <span class="dark-badge">LifeAdmin · Productivity Hub</span>

                        <h1 class="dark-title mt-3">
                            Manage your work
                            <br />
                            in one modern space.
                        </h1>

                        <p class="dark-subtitle">
                            LifeAdmin is a personal productivity web application built with ASP.NET Core MVC.
                            It helps users organize tasks, notes, categories, and documents in a secure and structured way.
                        </p>

                        <div class="dark-actions mt-4">
                            <a asp-area="Identity"
                               asp-page="/Account/Register"
                               class="btn btn-dark-primary">
                                Get Started
                            </a>

                            <a asp-controller="Home"
                               asp-action="About"
                               class="btn btn-dark-secondary">
                                Learn More
                            </a>
                        </div>

                        <div class="dark-tags mt-4">
                            <span>Tasks</span>
                            <span>Notes</span>
                            <span>Documents</span>
                            <span>Dashboard</span>
                            <span>Admin Area</span>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="preview-panel">
                        <div class="preview-header">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>

                        <div class="preview-body">
                            <div class="preview-main">
                                <div class="preview-main-top">
                                    <div>
                                        <h5>Today’s Dashboard</h5>
                                        <p class="mb-0">Your productivity overview</p>
                                    </div>
                                    <span class="preview-status">Active</span>
                                </div>

                                <div class="preview-stats">
                                    <div class="preview-stat">
                                        <strong>12</strong>
                                        <span>Tasks</span>
                                    </div>
                                    <div class="preview-stat">
                                        <strong>8</strong>
                                        <span>Notes</span>
                                    </div>
                                    <div class="preview-stat">
                                        <strong>5</strong>
                                        <span>Docs</span>
                                    </div>
                                </div>

                                <div class="task-preview-list">
                                    <div class="task-preview-item">
                                        <span class="status-dot done"></span>
                                        <p>Finish About page styling</p>
                                    </div>
                                    <div class="task-preview-item">
                                        <span class="status-dot progress"></span>
                                        <p>Review document restore feature</p>
                                    </div>
                                    <div class="task-preview-item">
                                        <span class="status-dot planned"></span>
                                        <p>Polish mobile navigation</p>
                                    </div>
                                </div>
                            </div>

                            <div class="preview-side">
                                <h6>Quick access</h6>
                                <div class="quick-link-box">My Tasks</div>
                                <div class="quick-link-box">Notes</div>
                                <div class="quick-link-box">Documents</div>
                                <div class="quick-link-box">Profile</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-1">
            <div class="col-md-6 col-xl-4">
                <div class="dark-feature-card accent-card h-100">
                    <div class="feature-icon-dark">✓</div>
                    <h3>Organized workflow</h3>
                    <p>
                        Keep tasks, notes, and important information together in one structured workspace.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="dark-feature-card h-100">
                    <div class="feature-icon-dark">🔒</div>
                    <h3>Secure access</h3>
                    <p>
                        Authentication, authorization, and owner-based protection help keep content private.
                    </p>
                </div>
            </div>

            <div class="col-md-6 col-xl-4">
                <div class="dark-feature-card h-100">
                    <div class="feature-icon-dark">⚙</div>
                    <h3>Built with purpose</h3>
                    <p>
                        Clean architecture, service layer, testing, and responsive design in one project.
                    </p>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-1">
            <div class="col-lg-7">
                <div class="dark-info-card h-100">
                    <span class="section-label-dark">About the project</span>
                    <h2 class="section-title-dark">A practical ASP.NET Core MVC application</h2>
                    <p>
                        LifeAdmin is developed as part of my SoftUni training and is focused on building
                        a complete web application with real project structure, role-based functionality,
                        database logic, testing, and polished UI.
                    </p>
                    <p class="mb-0">
                        It combines personal productivity features with clean organization and maintainable design.
                    </p>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="dark-info-card h-100">
                    <span class="section-label-dark">Technology stack</span>
                    <div class="stack-tags-dark">
                        <span>ASP.NET Core MVC</span>
                        <span>C#</span>
                        <span>EF Core</span>
                        <span>SQL Server</span>
                        <span>Identity</span>
                        <span>Bootstrap 5</span>
                        <span>NUnit</span>
                        <span>Layered Architecture</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>