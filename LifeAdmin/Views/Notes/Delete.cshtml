@using ViewModels.NotesViewModels
@model NoteDeleteViewModel

@{
    ViewData["Title"] = "Delete Note";
}

<h1 class="mb-4">Delete Note</h1>

<div class="card p-4">
    <div class="card-body">
        <h4 class="mb-3 text-danger">Are you sure you want to delete this note?</h4>

        <div class="mb-4">
            <strong>Title:</strong> @Model.Title
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="All" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>