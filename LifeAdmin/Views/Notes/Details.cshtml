@using ViewModels.NotesViewModels
@model NoteDetailsViewModel

@{
    ViewData["Title"] = "Note Details";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="mb-1">@Model.Title</h1>
        <p class="text-muted mb-0">Created on @Model.CreatedOn.ToString("dd-MM-yyyy")</p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        <a asp-action="All" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="card p-4">
    <div class="card-body">
        <p class="mb-0" style="white-space: pre-line;">@Model.Content</p>
    </div>
</div>