@using ViewModels.ProfilesViewModels
@model ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex align-items-center gap-4">
                <div>
                    <img src="@(string.IsNullOrWhiteSpace(Model.ProfileImageUrl)
                             ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(Model.DisplayName ?? Model.Email) + "&background=6366f1&color=fff&size=128"
                             : Model.ProfileImageUrl)"
                         alt="Profile picture"
                         class="rounded-circle shadow-sm border"
                         style="width: 120px; height: 120px; object-fit: cover;" />
                </div>

                <div>
                    <h2 class="mb-1">
                        @(string.IsNullOrWhiteSpace(Model.DisplayName)
                                                ? $"{Model.FirstName} {Model.LastName}".Trim()
                                                : Model.DisplayName)
                    </h2>

                    <p class="text-muted mb-1">@Model.Email</p>

                    @if (!string.Equals(Model.UserName, Model.Email, StringComparison.OrdinalIgnoreCase))
                    {
                        <p class="text-muted mb-1">@Model.UserName</p>
                    }

                    <p class="mb-0">
                        @(string.IsNullOrWhiteSpace(Model.Bio) ? "No bio added yet." : Model.Bio)
                    </p>
                </div>
            </div>

            <hr />

            <div class="row">
                <div class="col-md-6">
                    <p><strong>First Name:</strong> @(string.IsNullOrWhiteSpace(Model.FirstName) ? "Not provided" : Model.FirstName)</p>
                    <p><strong>Last Name:</strong> @(string.IsNullOrWhiteSpace(Model.LastName) ? "Not provided" : Model.LastName)</p>
                    <p><strong>Phone Number:</strong> @(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber)</p>
                </div>

                <div class="col-md-6">
                    <p>
                        <strong>Created On:</strong>
                        @(Model.CreatedOn == default
                                                ? "Not available"
                                                : Model.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy"))
                    </p>
                </div>
            </div>

            <a asp-controller="Profile" asp-action="Edit" class="btn btn-primary">
                Edit Profile
            </a>
        </div>
    </div>
</div>