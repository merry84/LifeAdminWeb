@using LifeAdminModels.Models
@using LifeAdminServices.Contracts
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject ILayoutService LayoutService

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LifeAdmin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/about.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LifeAdmin.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm border-bottom py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand d-flex align-items-center gap-2 fw-bold"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    <span class="brand-logo">L</span>
                    <span class="d-flex flex-column lh-sm">
                        <span class="brand-title">LifeAdmin</span>
                        <small class="text-muted brand-subtitle">Productivity Hub</small>
                    </span>
                </a>

                <button class="navbar-toggler border-0 shadow-none"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav mx-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link nav-pill"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index">
                                Dashboard
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-pill"
                                   asp-area=""
                                   asp-controller="Tasks"
                                   asp-action="All">
                                    My Tasks
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link nav-pill"
                                   asp-area=""
                                   asp-controller="Profile"
                                   asp-action="Mine">
                                    Profile
                                </a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link nav-pill dropdown-toggle"
                                   href="#"
                                   id="workspaceMenu"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Workspace
                                </a>

                                <ul class="dropdown-menu dropdown-menu-modern border-0 shadow" aria-labelledby="workspaceMenu">
                                    <li class="dropdown-header text-uppercase small text-muted px-3">Workspace</li>
                                    <li>
                                        <a class="dropdown-item py-2"
                                           asp-area=""
                                           asp-controller="Notes"
                                           asp-action="All">
                                            Notes
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2"
                                           asp-area=""
                                           asp-controller="Documents"
                                           asp-action="All">
                                            Documents
                                        </a>
                                    </li>

                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li class="dropdown-header text-uppercase small text-muted px-3">Admin Tools</li>

                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-area="Admin"
                                               asp-controller="Users"
                                               asp-action="All">
                                                Users
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-area="Admin"
                                               asp-controller="Dashboard"
                                               asp-action="Index">
                                                Admin Dashboard
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-area=""
                                               asp-controller="Tasks"
                                               asp-action="AllUsers">
                                                All Tasks
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-area=""
                                               asp-controller="Tasks"
                                               asp-action="Deleted">
                                                Deleted Tasks
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-area=""
                                               asp-controller="Notes"
                                               asp-action="Deleted">
                                                Deleted Notes
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-area=""
                                               asp-controller="Documents"
                                               asp-action="Deleted">
                                                Deleted Documents
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2"
                                               asp-area=""
                                               asp-controller="Categories"
                                               asp-action="All">
                                                Categories
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link nav-pill"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="About">
                                About
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-pill"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Privacy">
                                Privacy
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center ms-lg-3">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <partial name="_Notifications" />

    <main role="main" class="container flex-grow-1 py-3">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted py-2 mt-auto">
        <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                &copy; 2026 - LifeAdmin
            </div>
            <div class="d-flex gap-3">
                <a asp-area="" asp-controller="Home" asp-action="About">About</a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var toasts = document.querySelectorAll('.js-toast');

            toasts.forEach(function (el) {
                var toast = new bootstrap.Toast(el, {
                    autohide: true,
                    delay: 3500
                });

                toast.show();
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>