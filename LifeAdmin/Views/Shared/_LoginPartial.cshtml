@using LifeAdminModels.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-auto align-items-center">
    @if (SignInManager.IsSignedIn(User))
    {
        var appUser = await UserManager.GetUserAsync(User);
        var firstName = appUser?.FirstName;
        var display = string.IsNullOrWhiteSpace(firstName)
        ? (User.Identity?.Name ?? "Account")
        : firstName;

        <li class="nav-item dropdown">
            <a class="nav-link nav-pill-dark dropdown-toggle"
               href="#"
               id="userMenu"
               role="button"
               data-bs-toggle="dropdown"
               aria-expanded="false">
                <span class="fw-semibold">Hello, @display</span>
            </a>

            <ul class="dropdown-menu dropdown-menu-dark-modern dropdown-menu-end"
                aria-labelledby="userMenu">
                <li>
                    <a class="dropdown-item"
                       asp-area=""
                       asp-controller="Profile"
                       asp-action="Mine">
                        My Profile
                    </a>
                </li>
                <li>
                    <a class="dropdown-item"
                       asp-area="Identity"
                       asp-page="/Account/Manage/Index">
                        Account Settings
                    </a>
                </li>
                <li>
                    <hr class="dropdown-divider" />
                </li>
                <li>
                    <form asp-area="Identity"
                          asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                          method="post"
                          class="m-0">
                        <button type="submit" class="dropdown-item">
                            Logout
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link nav-pill-dark"
               asp-area="Identity"
               asp-page="/Account/Register">
                Register
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link nav-pill-dark"
               asp-area="Identity"
               asp-page="/Account/Login">
                Login
            </a>
        </li>
    }
</ul>