@model TaskQueryViewModel
@using LifeAdminModels.Models
@using ViewModels.TasksViewModels

@functions {
    string StatusBadgeClass(WorkStatus status) => status switch
    {
        WorkStatus.Planned => "bg-secondary",
        WorkStatus.InProgress => "bg-primary",
        WorkStatus.Done => "bg-success",
        _ => "bg-dark"
    };

    string StatusText(WorkStatus status) => status switch
    {
        WorkStatus.Planned => "Planned",
        WorkStatus.InProgress => "In Progress",
        WorkStatus.Done => "Done",
        _ => status.ToString()
    };
}

@{
    ViewData["Title"] = "My Tasks";
    int totalPages = (int)Math.Ceiling((double)Model.TotalTasksCount / Model.TasksPerPage);
}

<h1 class="mb-4">My Tasks</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <input asp-for="SearchTerm" class="form-control" placeholder="Search by title..." />
    </div>

    <div class="col-md-3">
        <select asp-for="CategoryId" class="form-select">
            <option value="">All Categories</option>
            @foreach (var category in Model.Categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <select asp-for="Status" class="form-select">
            <option value="">All Statuses</option>
            <option value="0">Planned</option>
            <option value="1">In Progress</option>
            <option value="2">Done</option>
        </select>
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
</form>

@if (!Model.Tasks.Any())
{
    <div class="alert alert-info">No tasks found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-striped align-middle">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Tags</th>
                    <th>Status</th>
                    <th>Created On</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in Model.Tasks)
                {
                    <tr>
                        <td class="fw-semibold">@task.Title</td>
                        <td>@task.CategoryName</td>
                        <td>
                            @if (task.Tags.Any())
                            {
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var tag in task.Tags)
                                    {
                                        <span class="badge bg-secondary">@tag</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">No tags</span>
                            }
                        </td>
                        <td>
                            <span class="badge @StatusBadgeClass(task.Status)">
                                @StatusText(task.Status)
                            </span>
                        </td>
                        <td>@task.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-end">
                            <div class="d-flex flex-wrap justify-content-end gap-2">
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-action="Details"
                                   asp-route-id="@task.Id">Details</a>

                                <a class="btn btn-sm btn-outline-primary"
                                   asp-action="Edit"
                                   asp-route-id="@task.Id">Edit</a>

                                <a class="btn btn-sm btn-outline-danger"
                                   asp-action="Delete"
                                   asp-route-id="@task.Id">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="All"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-status="@Model.Status"
                       asp-route-currentPage="@i">
                        @i
                    </a>
                </li>
            }
        </ul>
    </nav>
}